# Copy to .env and fill in real values. All three are required.

# PostgreSQL connection string (Neon, Vercel Postgres, Supabase, or self-hosted).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/pepfinds?sslmode=require"

# Password for the /admin area.
ADMIN_PASSWORD=""

# Secret used to sign admin session cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=""
